# ── Supabase（フロント公開可・RLS前提） ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://lxkvzofgzkksujoipnso.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key をここに>

# ── サーバー側のみ（絶対にフロントへ出さない / NEXT_PUBLIC_ を付けない） ──
# RLSを完全バイパスする最強権限。Edge Function・管理処理でのみ使用。
SUPABASE_SERVICE_ROLE_KEY=<service role key をここに>

# ── 外部フィード（該当フェーズで設定） ───────────────────
# CRYPTO_API_KEY=
# FX_API_KEY=
# SPORTS_API_KEY=
# DLOGIC_BASE_URL=
# Polymarket Gamma は認証不要（鍵なし）

# ── 決済（Phase 8） ──────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── LINEログイン（サーバー専用・Vercelに設定） ─────────────
# LINE_LOGIN_CHANNEL_ID=            # LINE Login チャネルのChannel ID
# LINE_LOGIN_CHANNEL_SECRET=        # 同 Channel Secret
# LINE_AUTH_SECRET=                 # セッション用決定的パスワードの署名秘密（任意のランダム文字列）
# NEXT_PUBLIC_SITE_URL=https://dmarket-six.vercel.app   # リダイレクトURI生成に使用
# SUPABASE_SERVICE_ROLE_KEY=        # ユーザー作成に使用（NEXT_PUBLIC を付けない・サーバー専用）
